# Investment Dashboard — example environment variables.
# Copy this file to `.env` and adjust as needed. The .env file is gitignored.

# Legacy single-file SQLite path. If set, all storage tiers share this file.
# INV_DASHBOARD_DB_PATH=C:\Users\me\AppData\Local\inv-dashboard\db.sqlite

# Optional v2.0 split-tier paths. If unset, ledger/config prefer a detected
# cloud-sync root and cache stays in the platform-local data directory.
# INV_DASHBOARD_LEDGER_PATH=C:\Users\me\OneDrive\inv-dashboard\ledger.sqlite
# INV_DASHBOARD_CONFIG_PATH=C:\Users\me\OneDrive\inv-dashboard\config.sqlite
# INV_DASHBOARD_CACHE_PATH=C:\Users\me\AppData\Local\inv-dashboard\cache.sqlite

# Optional SQLCipher encryption for ledger/config tiers.
# INV_DASHBOARD_ENCRYPT_SYNCED_TIERS=false
# INV_DASHBOARD_DB_PASSPHRASE=

# Network bind address and port for the NiceGUI server.
INV_DASHBOARD_HOST=0.0.0.0
INV_DASHBOARD_PORT=8080

# Log level: DEBUG, INFO, WARNING, ERROR.
INV_DASHBOARD_LOG_LEVEL=INFO

# Logs are written to a rotating dashboard.log next to your database by default
# (a logs/ folder beside INV_DASHBOARD_DB_PATH). Override the directory, the
# per-file size cap, and how many rolled-over files to keep here. You can also
# grab the same logs from the app: Data Health → "Download support bundle".
# INV_DASHBOARD_LOG_DIR=C:\Users\me\AppData\Local\inv-dashboard\logs
# INV_DASHBOARD_LOG_MAX_BYTES=2000000
# INV_DASHBOARD_LOG_BACKUP_COUNT=5

# --- Mobile companion: read-only JSON API (Phase 2) -------------------------
# Mount the read-only JSON API at /api on the NiceGUI server. Off by default
# so the standard LAN experience is unchanged.
# INV_DASHBOARD_API_ENABLED=false
# Optional bearer token guarding every /api route. Leave unset on a trusted
# LAN; set it (any long random string) the moment the server is reachable
# beyond the LAN, e.g. through a VPN or reverse proxy.
# INV_DASHBOARD_API_TOKEN=
# Output path for `inv-dashboard-export-snapshot`. Defaults to a
# mobile_snapshot.json beside the config tier so it rides your existing
# consumer-cloud sync (OneDrive/iCloud/Dropbox/Google Drive).
# INV_DASHBOARD_SNAPSHOT_PATH=C:\Users\me\OneDrive\inv-dashboard\mobile_snapshot.json

# --- Live web companion: encrypted publish (v3.0 Phase 2) -------------------
# Publish an AES-256-GCM-encrypted portfolio snapshot to a GitHub release so a
# browser companion can show live figures on the go. All off by default.
# INV_DASHBOARD_PUBLISH_ENABLED=false
# Target repo hosting the Pages app + the encrypted release asset.
# INV_DASHBOARD_PUBLISH_REPO=DJH961/Investment-Overview
# Release tag whose single asset is overwritten each publish.
# INV_DASHBOARD_PUBLISH_RELEASE_TAG=live-data
# Include the transaction list in the export (larger blob).
# INV_DASHBOARD_PUBLISH_INCLUDE_TRANSACTIONS=false
# Secrets normally live in the OS keychain (Settings -> Live web companion).
# Set these only for CI/headless publishing; never commit real values.
# INV_DASHBOARD_PUBLISH_TOKEN=
# INV_DASHBOARD_MOBILE_PASSPHRASE=

# --- Developer tools --------------------------------------------------------
# Optional password gating the Settings -> Developer tools panel (the full
# audit export that bundles every dashboard plus the raw ledger into one JSON
# file). Leave unset to keep it ungated on a single-user machine.
# INV_DASHBOARD_DEV_PASSWORD=

# --- Shutdown ---------------------------------------------------------------
# Quit the server a few seconds after the last browser tab closes, releasing
# the single-writer lock so other instances can run. Off by default so a
# server you leave open on purpose keeps running; you can also toggle this
# from Settings → Server (the toggle there is persisted and wins over this).
# INV_DASHBOARD_SHUTDOWN_ON_TAB_CLOSE=false

