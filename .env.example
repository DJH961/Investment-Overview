# Investment Dashboard — example environment variables.
# Copy this file to `.env` and adjust as needed. The .env file is gitignored.

# Legacy single-file SQLite path. If set, all storage tiers share this file.
# INV_DASHBOARD_DB_PATH=C:\Users\me\AppData\Local\inv-dashboard\db.sqlite

# Optional v2.0 split-tier paths. If unset, ledger/config prefer a detected
# cloud-sync root and cache stays in the platform-local data directory.
# INV_DASHBOARD_LEDGER_PATH=C:\Users\me\OneDrive\inv-dashboard\ledger.sqlite
# INV_DASHBOARD_CONFIG_PATH=C:\Users\me\OneDrive\inv-dashboard\config.sqlite
# INV_DASHBOARD_CACHE_PATH=C:\Users\me\AppData\Local\inv-dashboard\cache.sqlite

# Optional SQLCipher encryption for ledger/config tiers.
# INV_DASHBOARD_ENCRYPT_SYNCED_TIERS=false
# INV_DASHBOARD_DB_PASSPHRASE=

# Network bind address and port for the NiceGUI server.
INV_DASHBOARD_HOST=0.0.0.0
INV_DASHBOARD_PORT=8080

# Log level: DEBUG, INFO, WARNING, ERROR.
INV_DASHBOARD_LOG_LEVEL=INFO
